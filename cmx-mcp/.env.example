# Prototype only. Copy to a local ignored file or inject through the MCP client.
# Never commit a real access token.

# Connect locally so MCP traffic does not traverse Cloudflare.
CMX_MASTODON_BASE_URL=http://127.0.0.1:8080
# Send the current WEB_DOMAIN as Host so Rails HostAuthorization accepts the request.
CMX_MASTODON_HOST=pi.ler428.xyz
CMX_MASTODON_TOKEN=
CMX_PROFILE=reader
CMX_MEDIA_ROOT=D:\AI\PI-Personal-Instance-OS\mcp-uploads\example-bot
CMX_DEFAULT_VISIBILITY=private
CMX_MAX_ITEMS=30
CMX_MAX_MEDIA_BYTES=41943040
CMX_TIMEOUT_SECONDS=20
CMX_ALLOW_REMOTE_BASE_URL=false
